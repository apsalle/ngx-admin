    "@angular/forms": "^19.2.0",
    "@angular/google-maps": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@asymmetrik/ngx-leaflet": "18.0.1",
    "@nebular/auth": "15.0.0",
    "@nebular/eva-icons": "15.0.0",
    "@nebular/security": "15.0.0",
    "@nebular/theme": "15.0.0",
    "@swimlane/ngx-charts": "^23.1.0",
    "angular2-smart-table": "^4.1.1",
    "bootstrap": "4.3.1",
    "chart.js": "^4.4.0",
    "ckeditor4": "^4.22.0",
    "echarts": "^5.5.0",
    "eva-icons": "^1.1.3",
    "ionicons": "2.0.1",
    "leaflet": "^1.9.4",
    "lodash-es": "^4.17.21",
    "nebular-icons": "1.1.0",
    "ng2-ckeditor": "^1.3.7",
    "ng2-completer": "^9.0.1",
    "ngx-echarts": "19.0.0",
    "normalize.css": "6.0.0",
    "pace-js": "1.0.2",
    "roboto-fontface": "0.8.0",
    "rxjs": "^7.8.0",
    "socicon": "3.0.5",
    "tinymce": "^5.10.0",
