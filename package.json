    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.0",
    "sass": "^1.70.0",
    "stylelint": "^16.0.0",
    "typescript": "~5.5.0",
    "typescript-eslint": "^8.58.0"
  },
  "overrides": {
    "@asymmetrik/ngx-leaflet": {
      "@angular/core": ">=19.0.0",
      "@angular/common": ">=19.0.0"
    }
  }
